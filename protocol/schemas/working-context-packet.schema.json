{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/working-context-packet.schema.json",
  "title": "Localize Anything Working Context Packet",
  "type": "object",
  "required": ["protocol_version", "schema", "artifact", "status", "selection_artifact", "eligibility_artifact", "operating_mode", "source_locale", "target_locale", "scenario", "domains", "hard_constraints", "negative_constraints", "tm_suggestions", "style_guidance", "retrieved_examples", "reference_only_context", "claim_constraints", "revision_hints", "risk_notes", "scenario_rules", "hard_constraint_conflicts", "excluded_knowledge", "provenance", "knowledge_policy"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-working-context-packet-v1" },
    "artifact": { "const": "working-context-packet.json" },
    "status": { "enum": ["ready", "empty", "blocked"] },
    "selection_artifact": { "const": "knowledge-pack-selection.json" },
    "eligibility_artifact": { "const": "knowledge-eligibility-report.json" },
    "operating_mode": { "type": "string" },
    "source_locale": { "type": "string" },
    "target_locale": { "type": "string" },
    "scenario": { "type": "string" },
    "domains": { "type": "array", "items": { "type": "string" } },
    "hard_constraints": { "type": "array", "items": { "type": "object" } },
    "negative_constraints": { "type": "array", "items": { "type": "object" } },
    "tm_suggestions": { "type": "array", "items": { "type": "object" } },
    "style_guidance": { "type": "array", "items": { "type": "object" } },
    "retrieved_examples": { "type": "array", "items": { "type": "object" } },
    "reference_only_context": { "type": "array", "items": { "type": "object" } },
    "claim_constraints": { "type": "array", "items": { "type": "object" } },
    "revision_hints": { "type": "array", "items": { "type": "object" } },
    "risk_notes": { "type": "array", "items": { "type": "object" } },
    "scenario_rules": { "type": "object" },
    "hard_constraint_conflicts": { "type": "array", "items": { "type": "object" } },
    "excluded_knowledge": { "type": "array", "items": { "type": "object" } },
    "provenance": { "type": "array", "items": { "type": "object" } },
    "knowledge_policy": { "type": "object" }
  },
  "additionalProperties": true
}

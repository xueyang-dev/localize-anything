{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/provider-result-qa-report.schema.json",
  "title": "Localize Anything Provider Result QA Report",
  "type": "object",
  "required": ["protocol_version", "schema", "artifact", "status", "summary", "results", "qa_items", "forbidden_claims", "provider_or_model_called_by_runtime"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-provider-result-qa-report-v1" },
    "artifact": { "const": "provider-result-qa-report.json" },
    "status": { "enum": ["passed", "blocked", "requires_human_review", "not_run"] },
    "summary": { "type": "object" },
    "results": { "type": "array", "items": { "type": "object" } },
    "qa_items": { "type": "array", "items": { "type": "object" } },
    "forbidden_claims": { "type": "array", "items": { "type": "string" } },
    "provider_or_model_called_by_runtime": { "const": false }
  },
  "additionalProperties": true
}

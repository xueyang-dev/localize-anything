{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/delivery-decision.schema.json",
  "title": "Localize Anything Delivery Decision Report",
  "type": "object",
  "required": [
    "protocol_version",
    "evidence_channels",
    "run_id",
    "status",
    "delivery_directory",
    "project_root",
    "safety",
    "summary",
    "apply_plan",
    "decisions",
    "next_actions"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "evidence_channels": {
      "type": "array",
      "items": { "enum": ["runtime", "agent", "human", "llm"] }
    },
    "run_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["blocked", "owner_review_required", "ready_no_changes"] },
    "delivery_directory": { "type": "string", "minLength": 1 },
    "project_root": { "type": "string", "minLength": 1 },
    "safety": {
      "type": "object",
      "required": [
        "staged_copy_required",
        "apply_requires_run_id_confirmation",
        "automatic_source_edits",
        "backup_required_for_replacements"
      ],
      "properties": {
        "staged_copy_required": { "type": "boolean" },
        "apply_requires_run_id_confirmation": { "type": "boolean" },
        "automatic_source_edits": { "type": "boolean" },
        "backup_required_for_replacements": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "decision_count",
        "blocking_count",
        "requires_confirmation_count",
        "requires_review_count",
        "output_count",
        "qa_status",
        "apply_summary"
      ],
      "additionalProperties": true
    },
    "localization": { "type": "object", "additionalProperties": true },
    "apply_plan": { "$ref": "apply-plan.schema.json" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "severity", "status", "recommendation", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "enum": [
              "qa_finding",
              "apply_operation",
              "unprocessed_asset",
              "artifact_state",
              "preserved_translation",
              "generated_candidate",
              "stale_translation",
              "obsolete_target_reference"
            ]
          },
          "severity": { "enum": ["info", "warning", "blocking"] },
          "status": { "enum": ["informational", "requires_review", "requires_confirmation", "blocked"] },
          "recommendation": { "type": "string", "minLength": 1 },
          "evidence": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/repair-request.schema.json",
  "title": "Localize Anything Repair Request",
  "type": "object",
  "required": [
    "protocol_version",
    "schema",
    "status",
    "segment_regeneration_plan_path",
    "summary",
    "requests"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-repair-request-v1" },
    "run_id": { "type": ["string", "null"] },
    "status": { "enum": ["ready", "pending_repairs", "blocked"] },
    "segment_regeneration_plan_path": { "const": "segment-regeneration-plan.json" },
    "summary": {
      "type": "object",
      "required": ["request_count", "human_confirmation_required_count", "provider_or_model_required_count"],
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "repair_id",
          "segment_id",
          "source_artifact_refs",
          "repair_type",
          "reason",
          "old_target",
          "required_constraints",
          "risk_level",
          "human_confirmation_required",
          "provider_or_model_required",
          "status"
        ],
        "properties": {
          "repair_id": { "type": "string", "minLength": 1 },
          "segment_id": { "type": "string", "minLength": 1 },
          "source_artifact_refs": { "type": "object", "additionalProperties": { "type": "string" } },
          "repair_type": {
            "enum": [
              "term_patch",
              "placeholder_patch",
              "markup_patch",
              "risk_wording_patch",
              "style_patch",
              "coverage_patch",
              "review_only",
              "regenerate_segment"
            ]
          },
          "reason": { "type": "string" },
          "old_target": { "type": ["string", "null"] },
          "previous_target_hash": { "type": ["string", "null"] },
          "source_hash": { "type": ["string", "null"] },
          "required_constraints": { "type": "object", "additionalProperties": true },
          "risk_level": { "type": "string" },
          "human_confirmation_required": { "type": "boolean" },
          "deterministic_qa_required": { "type": "boolean" },
          "provider_or_model_required": { "type": "boolean" },
          "status": { "enum": ["pending_provider_or_model_repair", "pending_human_confirmation", "pending_review"] },
          "plan_status": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

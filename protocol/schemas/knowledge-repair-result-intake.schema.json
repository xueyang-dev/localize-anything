{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/knowledge-repair-result-intake.schema.json",
  "title": "Localize Anything Knowledge Repair Result Intake Record",
  "type": "object",
  "required": ["protocol_version", "schema", "result_id", "source_repair_request_id", "affected_segment_ids", "affected_scope", "result_source", "actor_role", "actor_reference", "repair_mode", "submitted_target_hash", "previous_target_hash", "repaired_target_hash", "source_knowledge_item_ids", "source_constraint_ids", "source_conflict_ids", "provenance_references", "claimed_fix_types", "limitations", "submitted_at", "status", "system_provider_or_model_execution_performed"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-knowledge-repair-result-intake-v1" },
    "result_id": { "type": "string", "minLength": 1 },
    "source_repair_request_id": { "type": "string" },
    "source_repair_plan_item_id": { "type": "string" },
    "affected_segment_ids": { "type": "array", "items": { "type": "string" } },
    "affected_scope": { "type": "object" },
    "result_source": { "enum": ["manual_repair", "deterministic_local_patch", "external_provider_result", "external_model_result", "reviewer_edit", "imported_patch", "unknown"] },
    "actor_role": { "type": "string" },
    "actor_reference": { "type": "string" },
    "repair_mode": { "enum": ["term_patch", "forbidden_translation_patch", "human_rewrite", "provider_repair", "model_repair", "regenerate_with_constraints", "scope_limit", "no_change_accepted", "not_applicable"] },
    "submitted_target_hash": { "type": "string" },
    "previous_target_hash": { "type": "string" },
    "repaired_target_hash": { "type": "string" },
    "repaired_target_text": { "type": "string" },
    "source_knowledge_item_ids": { "type": "array", "items": { "type": "string" } },
    "source_constraint_ids": { "type": "array", "items": { "type": "string" } },
    "source_conflict_ids": { "type": "array", "items": { "type": "string" } },
    "provenance_references": { "type": "array", "items": { "type": "string" } },
    "claimed_fix_types": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "submitted_at": { "type": "string" },
    "status": { "enum": ["received", "accepted_for_qa", "rejected_shape", "rejected_stale", "rejected_provenance", "requires_follow_up"] },
    "draft_or_review_only": { "type": "boolean" },
    "system_provider_or_model_execution_performed": { "const": false }
  },
  "additionalProperties": true
}

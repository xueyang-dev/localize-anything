{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/knowledge-audit-enforcement-decision.schema.json",
  "title": "Localize Anything Knowledge Audit Enforcement Decision",
  "type": "object",
  "required": [
    "protocol_version",
    "schema",
    "artifact",
    "status",
    "knowledge_pack_selection_status",
    "working_context_freshness",
    "usage_report_status",
    "constraint_audit_status",
    "conflict_report_status",
    "readiness_impact",
    "forbidden_claims",
    "required_next_actions",
    "source_artifacts"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-knowledge-audit-enforcement-decision-v1" },
    "artifact": { "const": "knowledge-audit-enforcement-decision.json" },
    "status": { "enum": ["clear", "clear_with_warnings", "review_required", "blocked", "stale", "not_applicable"] },
    "knowledge_pack_selection_status": { "type": "string" },
    "working_context_freshness": { "type": "string" },
    "usage_report_status": { "type": "string" },
    "constraint_audit_status": { "type": "string" },
    "conflict_report_status": { "type": "string" },
    "hard_constraint_application_status": { "type": "string" },
    "negative_constraint_check_status": { "type": "string" },
    "reference_only_leakage_status": { "type": "string" },
    "blind_benchmark_firewall_status": { "type": "string" },
    "unresolved_conflicts": { "type": "array", "items": { "type": "object" } },
    "failed_audits": { "type": "array", "items": { "type": "object" } },
    "pending_reviews": { "type": "array", "items": { "type": "object" } },
    "stale_evidence": { "type": "array", "items": { "type": "object" } },
    "issues": { "type": "array", "items": { "type": "object" } },
    "readiness_impact": { "type": "object" },
    "forbidden_claims": { "type": "array", "items": { "type": "string" } },
    "required_next_actions": { "type": "array", "items": { "type": "string" } },
    "source_artifacts": { "type": "object" }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/provider-evidence-reconciliation.schema.json",
  "title": "Localize Anything Provider Evidence Reconciliation",
  "type": "object",
  "required": ["protocol_version", "schema", "artifact", "status", "provider_execution_complete_supported", "provider_backed_quality_supported", "forbidden_claims_remaining"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-provider-evidence-reconciliation-v1" },
    "artifact": { "const": "provider-evidence-reconciliation.json" },
    "status": { "enum": ["clear", "clear_with_warnings", "blocked", "failed", "stale", "not_applicable", "review_required"] },
    "provider_execution_complete_supported": { "type": "boolean" },
    "provider_backed_quality_supported": { "type": "boolean" },
    "forbidden_claims_remaining": { "type": "array", "items": { "type": "string" } },
    "reconciled_results": { "type": "array" }
  },
  "additionalProperties": true
}

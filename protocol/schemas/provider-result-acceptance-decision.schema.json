{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/provider-result-acceptance-decision.schema.json",
  "title": "Localize Anything Provider Result Acceptance Decision",
  "type": "object",
  "required": ["protocol_version", "schema", "artifact", "decision_id", "status", "result_ids", "effective_scope", "forbidden_claims_remaining", "provider_or_model_called_by_runtime"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-provider-result-acceptance-decision-v1" },
    "artifact": { "const": "provider-result-acceptance-decision.json" },
    "decision_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["accepted", "accepted_with_limitations", "rejected", "blocked"] },
    "result_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "effective_scope": { "type": "object", "minProperties": 1 },
    "forbidden_claims_remaining": { "type": "array", "items": { "type": "string" } },
    "provider_or_model_called_by_runtime": { "const": false }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/apply-plan.schema.json",
  "title": "Localize Anything Apply Plan",
  "type": "object",
  "required": ["protocol_version", "run_id", "mode", "project_root", "operations", "summary"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "run_id": { "type": "string" },
    "mode": { "const": "dry_run" },
    "project_root": { "type": "string" },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "source", "destination", "source_sha256"],
        "properties": {
          "action": { "enum": ["create", "replace", "unchanged", "conflict"] },
          "source": { "type": "string" },
          "destination": { "type": "string" },
          "source_sha256": { "type": "string" },
          "destination_sha256": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": ["create", "replace", "unchanged", "conflict"],
      "additionalProperties": { "type": "integer", "minimum": 0 }
    }
  },
  "additionalProperties": true
}

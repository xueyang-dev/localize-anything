{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/localization-brief.schema.json",
  "title": "Localize Anything Localization Brief",
  "type": "object",
  "required": [
    "protocol_version",
    "schema",
    "status",
    "document_type",
    "source_genre",
    "target_mode",
    "target_audience",
    "style",
    "constraints",
    "allowed_transformations",
    "forbidden_behaviors",
    "task_intent",
    "source_surface",
    "strategy",
    "required_human_confirmations",
    "evidence"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-localization-brief-v1" },
    "status": { "enum": ["draft", "reviewed", "accepted"] },
    "document_type": { "type": "string", "minLength": 1 },
    "source_genre": { "type": "string", "minLength": 1 },
    "target_mode": { "type": "string", "minLength": 1 },
    "target_audience": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "style": { "type": "object", "additionalProperties": true },
    "allowed_transformations": { "type": "array", "items": { "type": "string" } },
    "forbidden_behaviors": { "type": "array", "items": { "type": "string" } },
    "task_intent": {
      "type": "object",
      "required": [
        "scenario",
        "source_locale",
        "target_locales",
        "operating_mode",
        "reference_policy",
        "target_delivery_form",
        "requires_user_confirmation"
      ],
      "properties": {
        "scenario": {
          "enum": ["project_localization", "software_resource_localization", "document_localization"]
        },
        "source_locale": { "type": "string", "minLength": 1 },
        "target_locales": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "operating_mode": {
          "enum": ["blind_benchmark", "greenfield_localization", "existing_locale_maintenance", "rewrite_or_harmonization"]
        },
        "reference_policy": {
          "enum": ["blind", "style_only", "tm_assisted", "preserve_existing"]
        },
        "target_delivery_form": { "type": "string", "minLength": 1 },
        "requires_user_confirmation": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "source_surface": {
      "type": "object",
      "required": [
        "project_path",
        "detected_project_type",
        "supported_file_count",
        "selected_source_files",
        "adapter_counts",
        "unprocessed_non_text_asset_count"
      ],
      "properties": {
        "project_path": { "type": "string", "minLength": 1 },
        "detected_project_type": { "type": "string", "minLength": 1 },
        "primary_adapter": { "type": ["string", "null"] },
        "supported_file_count": { "type": "integer", "minimum": 0 },
        "selected_source_files": { "type": "array", "items": { "type": "string" } },
        "adapter_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "unprocessed_non_text_asset_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "strategy": {
      "type": "object",
      "required": ["workflow_depth", "preflight_mode", "privacy_mode", "data_classification", "style", "allowed_transformations", "forbidden_behaviors"],
      "properties": {
        "workflow_depth": { "type": "string", "minLength": 1 },
        "preflight_mode": { "type": "string", "minLength": 1 },
        "privacy_mode": { "type": "string", "minLength": 1 },
        "data_classification": { "type": "string", "minLength": 1 },
        "style": { "type": "object", "additionalProperties": true },
        "allowed_transformations": { "type": "array", "items": { "type": "string" } },
        "forbidden_behaviors": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "required": ["do_not_invent_facts", "preserve_core_data", "preserve_placeholders", "preserve_markup", "flag_unconfirmed_names"],
      "properties": {
        "do_not_invent_facts": { "type": "boolean" },
        "preserve_core_data": { "type": "boolean" },
        "preserve_placeholders": { "type": "boolean" },
        "preserve_markup": { "type": "boolean" },
        "flag_unconfirmed_names": { "type": "boolean" },
        "localize_policy_terms": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "required_human_confirmations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "reason", "status"],
        "properties": {
          "item": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "status": { "enum": ["required", "resolved"] }
        },
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "object",
      "required": ["derived_from", "confidence", "limitations"],
      "properties": {
        "derived_from": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string", "minLength": 1 },
        "limitations": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

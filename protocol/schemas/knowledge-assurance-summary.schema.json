{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/knowledge-assurance-summary.schema.json",
  "title": "Localize Anything Knowledge Assurance Summary",
  "type": "object",
  "required": [
    "protocol_version",
    "schema",
    "artifact",
    "status",
    "enforcement_decision_status",
    "human_knowledge_review_status",
    "conflict_resolution_status",
    "forbidden_claims_remaining",
    "supported_claims",
    "unsupported_claims",
    "readiness_impact",
    "source_artifacts"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-knowledge-assurance-summary-v1" },
    "artifact": { "const": "knowledge-assurance-summary.json" },
    "status": { "enum": ["review_required", "constraints_applied", "review_complete", "blocked", "stale"] },
    "pack_selection_status": { "type": "string" },
    "working_context_status": { "type": "string" },
    "usage_report_status": { "type": "string" },
    "constraint_audit_status": { "type": "string" },
    "enforcement_decision_status": { "type": "string" },
    "human_knowledge_review_status": { "type": "string" },
    "conflict_resolution_status": { "type": "string" },
    "constraints_accepted": { "type": "array", "items": { "type": "string" } },
    "constraints_rejected": { "type": "array", "items": { "type": "string" } },
    "conflicts_resolved": { "type": "array", "items": { "type": "object" } },
    "conflicts_remaining": { "type": "array", "items": { "type": "object" } },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "forbidden_claims_remaining": { "type": "array", "items": { "type": "string" } },
    "supported_claims": { "type": "array", "items": { "type": "string" } },
    "unsupported_claims": { "type": "array", "items": { "type": "string" } },
    "readiness_impact": { "type": "object" },
    "source_artifacts": { "type": "object" }
  },
  "additionalProperties": true
}

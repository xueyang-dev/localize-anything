{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/knowledge-audit-resolution-log.schema.json",
  "title": "Localize Anything Knowledge Audit Resolution Log Record",
  "type": "object",
  "required": [
    "protocol_version",
    "schema",
    "resolution_id",
    "decision_type",
    "reviewer_role",
    "reviewer_reference",
    "source_artifact_references",
    "decision_status",
    "effective_scope"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-knowledge-audit-resolution-log-v1" },
    "resolution_id": { "type": "string", "minLength": 1 },
    "decision_type": { "type": "string" },
    "reviewer_role": { "type": "string" },
    "reviewer_reference": { "type": "string" },
    "source_artifact_references": { "type": "array", "items": { "type": "string" } },
    "related_queue_item_id": { "type": "string" },
    "related_enforcement_decision_id": { "type": "string" },
    "related_knowledge_usage_item_id": { "type": "string" },
    "related_constraint_audit_id": { "type": "string" },
    "related_conflict_id": { "type": "string" },
    "affected_knowledge_item_ids": { "type": "array", "items": { "type": "string" } },
    "affected_segment_ids": { "type": "array", "items": { "type": "string" } },
    "decision_status": { "enum": ["accepted", "accepted_with_limitations", "rejected", "blocked", "requires_follow_up", "superseded", "stale"] },
    "rationale": { "type": "string" },
    "accepted_limitation": { "type": "string" },
    "required_follow_up": { "type": "string" },
    "effective_scope": { "type": "object" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}

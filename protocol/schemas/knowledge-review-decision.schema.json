{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/knowledge-review-decision.schema.json",
  "title": "Localize Anything Knowledge Review Decision",
  "type": "object",
  "required": ["protocol_version", "schema", "pack_id", "decision_id", "candidate_id", "decision", "reviewer_role", "created_at"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-knowledge-review-decision-v1" },
    "run_id": { "type": ["string", "null"] },
    "pack_id": { "type": "string", "minLength": 1 },
    "decision_id": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "decision": {
      "enum": [
        "approve",
        "lock",
        "reject",
        "defer",
        "scope_limit",
        "mark_reference_only",
        "mark_obsolete",
        "merge_duplicate",
        "requires_follow_up"
      ]
    },
    "reviewer_role": { "type": "string" },
    "reviewer_reference": { "type": "string" },
    "rationale": { "type": "string" },
    "effective_scope": { "type": "object" },
    "source_artifact_references": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string" },
    "supersedes": { "type": "array" },
    "superseded_by": { "type": "array" }
  },
  "additionalProperties": true
}

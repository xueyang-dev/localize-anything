{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/locale-risk-report.schema.json",
  "title": "Localize Anything Locale Risk Report",
  "type": "object",
  "required": ["protocol_version", "schema", "artifact", "status", "risks", "forbidden_claims"],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-locale-risk-report-v1" },
    "artifact": { "const": "locale-risk-report.json" },
    "status": { "enum": ["clear", "review_required", "blocked", "stale"] },
    "risks": { "type": "array" },
    "forbidden_claims": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}

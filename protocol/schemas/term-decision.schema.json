{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/term-decision.schema.json",
  "title": "Localize Anything Term Decision",
  "type": "object",
  "required": [
    "protocol_version",
    "source_term",
    "target_term",
    "type",
    "status",
    "priority",
    "scope",
    "provenance"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "source_term": { "type": "string", "minLength": 1 },
    "target_term": { "type": "string", "minLength": 1 },
    "type": {
      "enum": [
        "institution",
        "project",
        "policy_term",
        "award",
        "mechanism",
        "metric",
        "ui_term",
        "domain_term",
        "style_term",
        "other"
      ]
    },
    "status": {
      "enum": [
        "raw",
        "reference",
        "verified",
        "approved",
        "locked",
        "suggested",
        "risk",
        "rejected",
        "deprecated",
        "obsolete",
        "scope_specific"
      ]
    },
    "priority": {
      "enum": [
        "user_confirmed",
        "official",
        "project_specific",
        "reviewed_tm",
        "style_guide",
        "model_suggestion",
        "literal_guess",
        "unit_preserving",
        "style_approved"
      ]
    },
    "scope": { "type": "string" },
    "forbidden_targets": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "date": { "type": "string" },
          "source": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://localize-anything.dev/schemas/generation-strategy.schema.json",
  "title": "Localize Anything Generation Strategy Gate",
  "type": "object",
  "required": [
    "protocol_version",
    "schema",
    "source_locale",
    "target_locale",
    "operating_mode",
    "reference_policy",
    "status",
    "generation_readiness",
    "route",
    "gates",
    "work_packet_policy",
    "draft_request_policy",
    "blockers",
    "warnings",
    "artifacts",
    "limitations"
  ],
  "properties": {
    "protocol_version": { "const": "0.1" },
    "schema": { "const": "localize-anything-generation-strategy-v1" },
    "run_id": { "type": ["string", "null"] },
    "source_locale": { "type": "string", "minLength": 1 },
    "target_locale": { "type": "string", "minLength": 1 },
    "operating_mode": {
      "enum": ["blind_benchmark", "greenfield_localization", "existing_locale_maintenance", "rewrite_or_harmonization"]
    },
    "reference_policy": {
      "enum": ["blind", "style_only", "tm_assisted", "preserve_existing"]
    },
    "status": { "enum": ["ready", "review_required", "blocked"] },
    "generation_readiness": { "enum": ["ready", "review_required", "blocked"] },
    "route": {
      "type": "object",
      "required": ["mode", "assurance", "reason_codes"],
      "properties": {
        "mode": { "enum": ["standard_handoff", "high_assurance_handoff", "blocked"] },
        "assurance": { "enum": ["standard", "partial", "blocked"] },
        "reason_codes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "scope": { "type": "object", "additionalProperties": true },
    "gates": { "type": "object", "additionalProperties": true },
    "work_packet_policy": {
      "type": "object",
      "required": ["allow_generation", "include_hard_constraints", "include_terminology_review", "include_generation_strategy"],
      "properties": {
        "allow_generation": { "type": "boolean" },
        "include_hard_constraints": { "type": "boolean" },
        "include_terminology_review": { "type": "boolean" },
        "include_generation_strategy": { "type": "boolean" },
        "blocked_reason_codes": { "type": "array", "items": { "type": "string" } },
        "warning_codes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "draft_request_policy": { "type": "object", "additionalProperties": true },
    "blockers": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "warnings": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "artifacts": {
      "type": "object",
      "required": ["generation_strategy"],
      "properties": {
        "generation_strategy": { "const": "generation-strategy.json" },
        "localization_brief": { "const": "localization-brief.json" },
        "termbase_preflight_report": { "const": "termbase-preflight-report.json" }
      },
      "additionalProperties": true
    },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}

{
  "protocol_version": "0.1",
  "id": "core.yaml-toml",
  "name": "Core YAML and TOML Resource Adapter",
  "version": "0.1.0",
  "implementation_status": "implemented",
  "trust": "core",
  "formats": ["yaml", "toml"],
  "extensions": [".yaml", ".yml", ".toml"],
  "capabilities": ["detect", "inventory", "extract", "validate_source", "rebuild", "validate_output", "plan_apply"],
  "round_trip_level": "extract_and_rebuild",
  "permissions": ["read_project", "write_staging"],
  "runtime": {
    "type": "python",
    "version": ">=3.11",
    "dependencies": [{"name": "PyYAML", "version": ">=6.0,<7"}]
  },
  "entrypoints": {
    "extract": ["python3", "-m", "runtime.localize_anything", "extract-structured"],
    "rebuild": ["python3", "-m", "runtime.localize_anything", "rebuild-structured"],
    "validate_output": ["python3", "-m", "runtime.localize_anything", "validate-structured"]
  }
}

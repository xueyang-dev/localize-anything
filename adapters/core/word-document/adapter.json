{
  "protocol_version": "0.1",
  "id": "core.word-document",
  "name": "Core Word OpenXML Document Adapter",
  "version": "0.1.0",
  "implementation_status": "experimental",
  "trust": "core",
  "formats": ["docx", "dotx", "docm", "dotm"],
  "extensions": [".docx", ".dotx", ".docm", ".dotm"],
  "capabilities": ["detect", "inventory", "extract", "validate_source", "rebuild", "validate_output", "plan_apply"],
  "round_trip_level": "extract_and_rebuild",
  "permissions": ["read_project", "write_staging"],
  "runtime": {
    "type": "python",
    "version": ">=3.11",
    "dependencies": []
  },
  "entrypoints": {
    "extract": ["python3", "-m", "runtime.localize_anything", "extract-word"],
    "rebuild": ["python3", "-m", "runtime.localize_anything", "rebuild-word"],
    "validate_output": ["python3", "-m", "runtime.localize_anything", "validate-word"]
  }
}

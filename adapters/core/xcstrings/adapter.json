{
  "protocol_version": "0.1",
  "id": "core.xcstrings",
  "name": "Core Xcode String Catalog Adapter",
  "version": "0.2.0",
  "implementation_status": "experimental",
  "trust": "core",
  "formats": ["xcstrings"],
  "extensions": [".xcstrings"],
  "capabilities": ["detect", "inventory", "extract", "validate_source", "rebuild", "validate_output", "plan_apply"],
  "round_trip_level": "extract_and_rebuild",
  "permissions": ["read_project", "write_staging"],
  "runtime": {
    "type": "python",
    "version": ">=3.11",
    "dependencies": []
  },
  "entrypoints": {
    "extract": ["python3", "-m", "runtime.localize_anything", "extract-xcstrings"],
    "rebuild": ["python3", "-m", "runtime.localize_anything", "rebuild-xcstrings"],
    "validate_output": ["python3", "-m", "runtime.localize_anything", "validate-xcstrings"]
  }
}

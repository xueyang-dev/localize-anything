{
  "protocol_version": "0.1",
  "id": "core.xliff",
  "name": "Core XLIFF Adapter",
  "version": "0.1.0",
  "implementation_status": "implemented",
  "trust": "core",
  "formats": ["xliff-1.2", "xliff-2"],
  "extensions": [".xlf", ".xliff"],
  "capabilities": ["detect", "inventory", "extract", "validate_source", "rebuild", "validate_output", "plan_apply"],
  "round_trip_level": "full_round_trip",
  "permissions": ["read_project", "write_staging"],
  "runtime": {"type": "python", "version": ">=3.11", "dependencies": []},
  "entrypoints": {
    "extract": ["python3", "-m", "runtime.localize_anything", "extract-xliff"],
    "rebuild": ["python3", "-m", "runtime.localize_anything", "rebuild-xliff"],
    "validate_output": ["python3", "-m", "runtime.localize_anything", "validate-xliff"]
  }
}
